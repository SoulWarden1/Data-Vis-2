{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
        "url": "data/population_vs_cafes.csv"
    },
    "mark": {
        "type": "circle",
        "opacity": 0.8,
        "size": 100
    },
    "encoding": {
        "x": {
            "field": "Population",
            "type": "quantitative",
            "title": "Population",
            "scale": {
                "type": "log"
            }
        },
        "y": {
            "field": "cafe_count",
            "type": "quantitative",
            "title": "Number of Cafés",
            "scale": {
                "type": "log"
            }
        },
        "color": {
            "field": "cafe_density",
            "type": "quantitative",
            "title": "Cafés per 1000 People",
            "scale": {
                "scheme": "browns",
                "domain": [0, 6]
            },
            "legend": {
                "title": "Cafés per 1000 People",
                "orient": "bottom"
            }
        },
        "tooltip": [
            {
                "field": "LOCALITY",
                "type": "nominal",
                "title": "Suburb"
            },
            {
                "field": "Population",
                "type": "quantitative",
                "title": "Population"
            },
            {
                "field": "cafe_count",
                "type": "quantitative",
                "title": "Number of Cafés"
            },
            {
                "field": "cafe_density",
                "type": "quantitative",
                "title": "Cafés per 1000 People",
                "format": ".2f"
            }
        ]
    },
    "width": 600,
    "height": 500
}
