{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "../data/population_vs_cafes.csv"
  },
  "title": "Population vs. Café Density in Melbourne Suburbs",
  "mark": {
    "type": "circle",
    "opacity": 0.7,
    "size": 200
  },
  "encoding": {
    "x": {
      "field": "Population",
      "type": "quantitative",
      "title": "Population",
      "scale": {
        "type": "log"
      }
    },
    "y": {
      "field": "cafe_count",
      "type": "quantitative",
      "title": "Number of Cafés",
      "scale": {
        "type": "log"
      }
    },
    "color": {
      "field": "cafe_density",
      "type": "quantitative",
      "title": "Cafés per 1000 People",
      "scale": {
        "scheme": "browns"
      }
    },
    "tooltip": [
      {
        "field": "LOCALITY",
        "type": "nominal",
        "title": "Suburb"
      },
      {
        "field": "Population",
        "type": "quantitative",
        "title": "Population"
      },
      {
        "field": "cafe_count",
        "type": "quantitative",
        "title": "Number of Cafés"
      },
      {
        "field": "cafe_density",
        "type": "quantitative",
        "title": "Cafés per 1000 People",
        "format": ".2f"
      }
    ]
  },
  "width": 600,
  "height": 500
}
