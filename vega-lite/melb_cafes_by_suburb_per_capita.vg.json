{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

    "title": "Cafés per 1,000 People by Suburb",

    "width": "800",
    "height": 600,

    "projection": {
        "type": "identity",
        "reflectY": true
    },

    "data": {
        "url": "data/LOCALITY_POLYGON_WITH_COUNTS.json",
        "format": {
            "type": "json",
            "property": "features"
        }
    },

    "transform": [
        {
            "lookup": "properties.LOCALITY",
            "from": {
                "data": {
                    "url": "data/population_by_suburb.csv"
                },
                "key": "Suburb",
                "fields": ["Population"]
            }
        },

        {
            "calculate": "toNumber(datum.Population)",
            "as": "population_value"
        },

        {
            "filter": "datum.population_value >= 200"
        },

        {
            "calculate": "(datum.properties.cafe_count / datum.population_value) * 1000",
            "as": "cafes_per_1000"
        }
    ],

    "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.4
    },

    "encoding": {
        "color": {
            "field": "cafes_per_1000",
            "type": "quantitative",

            "scale": {
                "scheme": "orangered",
                "domain": [0, 6]
            },

            "legend": {
                "title": "Cafés per 1,000 people",
                "orient": "bottom"
            }
        },

        "tooltip": [
            {
                "field": "properties.LOCALITY",
                "type": "nominal",
                "title": "Suburb"
            },
            {
                "field": "properties.cafe_count",
                "type": "quantitative",
                "title": "Cafés"
            },
            {
                "field": "population_value",
                "type": "quantitative",
                "title": "Population"
            },
            {
                "field": "cafes_per_1000",
                "type": "quantitative",
                "title": "Cafés per 1,000 people",
                "format": ".2f"
            }
        ]
    }
}