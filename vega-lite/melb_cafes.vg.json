{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 600,

  "params": [
    { "name": "zoom",
    "value": 1,
    "bind": {
      "input": "range",
       "min": 0.5,
        "max": 5,
         "step": 0.1,
          "name": "Zoom: "
      }
  }
],

  "projection": {
    "type": "mercator",
    "center": [145.05, -37.9],
    "scale": { "signal": "zoom * 40000" }
  },

  "layer": [
    {
      "data": {
        "url": "data/LOCALITY_POLYGON.json",
        "format": {
          "type": "json"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f5f5f5",
        "stroke": "#999",
        "strokeWidth": 0.7
      }
    },
    {
      "data": {
        "url": "data/export.geojson",
        "format": {
          "type": "json",
          "property": "features"
        }
      },

      "transform": [
        {
          "calculate": "datum.geometry.type === 'Point' ? datum.geometry.coordinates[0] : null",
          "as": "longitude"
        },
        {
          "calculate": "datum.geometry.type === 'Point' ? datum.geometry.coordinates[1] : null",
          "as": "latitude"
        },
        {
          "filter": "datum.longitude != null && datum.latitude != null"
        }
      ],

      "mark": {
        "type": "circle",
        "color": "#6b4f3b",
        "opacity": 0.5,
        "size": 18
      },

      "encoding": {
        "longitude": {
          "field": "longitude",
          "type": "quantitative"
        },

        "latitude": {
          "field": "latitude",
          "type": "quantitative"
        },

        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "Name"
          }
        ]
      }
    }
  ]
}