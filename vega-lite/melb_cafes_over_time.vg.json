{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

    "width": 1000,
    "height": 200,

    "data": {
        "url": "data/cafes_by_year.csv"
    },

    "mark": {
        "type": "line",
        "size": 5
    },
    "encoding": {
        "x": {
            "field": "census_year",
            "type": "quantitative",
            "title": "Year",
            "axis": { "format": "d" },
            "scale": {"domain": [2002, 2024]}
        },
        "y": {
            "field": "Number of Cafes",
            "type": "quantitative",
            "title": null,
            "scale": {"domain": [0, 2100]}
        },
        "tooltip": [
            {
                "field": "census_year",
                "type": "quantitative",
                "title": "Year"
            },
            {
                "field": "Number of Cafes",
                "type": "quantitative",
                "title": "No. of Cafés"
            }
        ]
    }
}
