{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

    "width": 1000,
    "height": 250,

    "data": {
        "url": "data/coffee_consumption_per_capita.csv"
    },

    "encoding": {
        "y": {
            "field": "Location",
            "type": "nominal",
            "title": null,
            "sort": { "field": "Consumption", "op": "mean", "order": "descending" }
        },
        "tooltip": [
                {
                    "field": "Location",
                    "type": "nominal",
                    "title": "Location"
                },
                {
                    "field": "Consumption",
                    "type": "quantitative",
                    "title": "Consumption (kg per capita)"
                }
            ]
    },

    "layer": [
        {
            "mark": {
                "type": "bar",
                "size": 20
            },
            "encoding": {
                "x": {
                    "field": "Consumption",
                    "type": "quantitative",
                    "title": "Consumption (kg per capita)",
                    "axis": { "tickMinStep": 0.5 }
                }
            }
        },
        {
            "mark": {
                "type": "text",
                "align": "right",
                "baseline": "middle",
                "dx": -4,
                "color": "white"
            },
            "encoding": {
                "x": {
                    "field": "Consumption",
                    "type": "quantitative"
                },
                "text": {
                    "field": "Consumption",
                    "type": "quantitative",
                    "format": ".2f"
                }
            }
        }
    ]
}