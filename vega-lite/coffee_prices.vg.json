{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

    "width": 500,
    "height": 250,

    "data": {
        "url": "./data/coffee_prices.csv"
    },

    "encoding": {
        "y": {
            "field": "Location",
            "type": "nominal",
            "sort": { "field": "Price", "op": "mean", "order": "descending" },
            "title": null
        }
    },

    "layer": [
        {
            "mark": {
                "type": "bar",
                "size": 20,
                "color": "#6b4f3b"
            },
            "encoding": {
                "x": {
                    "field": "Price",
                    "type": "quantitative",
                    "title": "Price ($AUD)",
                    "axis": { "format": "$", "tickMinStep": 0.5 }
                }
            }
        },
        {
            "mark": {
                "type": "text",
                "color": "white",
                "align": "right",
                "baseline": "middle",
                "dx": -4
            },
            "encoding": {
                "x": {
                    "field": "Price",
                    "type": "quantitative"
                },
                "text": {
                    "field": "Price",
                    "type": "quantitative",
                    "format": "$"
                }
            }
        }
    ]
}
