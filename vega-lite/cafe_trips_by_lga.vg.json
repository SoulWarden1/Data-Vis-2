{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "width": 460,
    "height": 550,

    "data": {
        "url": "./data/cafe_trips_by_lga.csv"
    },

    "encoding": {
        "y": {
            "field": "origlga",
            "type": "nominal",
            "title": "LGA",
            "sort": { "field": "cumdist", "op": "mean", "order": "ascending" }
        }
    },

    "layer": [
        {
            "mark": {
                "type": "bar",
                "size": 15
            },

            "encoding": {
                "x": {
                    "field": "cumdist",
                    "type": "quantitative",
                    "title": "Average Distance to Café (km)"
                },

                "color": {
                    "field": "triptime",
                    "type": "quantitative",
                    "title": "Average Trip Time (min)",
                    "legend": {
                        "title": "Average Trip Time (min)",
                        "orient": "bottom"
                    }
                },

                "tooltip": [
                    {
                        "field": "origlga",
                        "type": "nominal",
                        "title": "LGA"
                    },
                    {
                        "field": "cumdist",
                        "type": "quantitative",
                        "title": "Avg Distance to Café (km)",
                        "format": ".2f"
                    },
                    {
                        "field": "triptime",
                        "type": "quantitative",
                        "title": "Avg Trip Time (min)",
                        "format": ".2f"
                    }
                ]
            }
        },

        {
            "mark": {
                "type": "text",
                "align": "right",
                "baseline": "middle",
                "dx": -5,
                "color": "white"
            },

            "encoding": {
                "x": {
                    "field": "cumdist",
                    "type": "quantitative"
                },

                "text": {
                    "field": "cumdist",
                    "type": "quantitative",
                    "format": ".2f"
                }
            }
        }
    ]
}